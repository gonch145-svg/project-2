      <column caption='Calculation1' datatype='string' name='[Calculation_6283761895870471]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [clnt_tenure_yr] &lt;= 1 THEN &quot;NEW CLIENT&quot;&#10;ELSEIF [clnt_tenure_yr] &lt;= 5 THEN &quot;MODERATELY NEW CLIENT&quot;&#10;ELSE &quot;OLD CLIENT&quot;&#10;END' />
      </column>
      <column datatype='string' name='[Clnt Age (group)]' role='dimension' type='nominal'>
        <calculation class='categorical-bin' column='[clnt_age]' new-bin='true'>
          <bin default-name='false' value='&quot;Middle-aged Clients&quot;'>
            <value>35.0</value>
            <value>35.5</value>
            <value>36.0</value>
            <value>36.5</value>
            <value>37.0</value>
