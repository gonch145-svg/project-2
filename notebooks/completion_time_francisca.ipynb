   "source": [
    "# Applying confirm filter only if exists\n",
    "f = df[\n",
    "    (df[\"last_confirm_time\"].isna()) | \n",
    "    (df[\"date_time\"] <= df[\"last_confirm_time\"])\n",
    "]"
