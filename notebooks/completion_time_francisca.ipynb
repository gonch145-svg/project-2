   "source": [
    "# Removing outliers\n",
    "Q1 = df_agg[\"step_duration\"].quantile(0.25)\n",
    "Q3 = df_agg[\"step_duration\"].quantile(0.75)\n",
    "\n",
    "IQR = Q3 - Q1\n",
    "\n",
    "lower_bound = Q1 - 1.5 * IQR\n",
    "upper_bound = Q3 + 1.5 * IQR"
   ]
  },
