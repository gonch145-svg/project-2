   "source": [
    "# Computing time difference\n",
    "df[\"next_time\"] = df.groupby(\"visit_id\")[\"date_time\"].shift(-1)\n",
    "\n",
    "df[\"step_duration\"] = (df[\"next_time\"] - df[\"date_time\"]).dt.total_seconds()"
   ]
  },
