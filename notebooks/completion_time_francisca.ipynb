   "source": [
    "# converting the \"date_time\" into a datetime type\n",
    "df[\"date_time\"] = pd.to_datetime(df[\"date_time\"])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "3744c14a-79cb-4658-ba28-85378cb07c4e",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Sort data\n",
    "df = df.sort_values([\"visit_id\", \"date_time\"])\n",
    "\n",
    "\n",
    "# Ordering the steps\n",
    "step_order = {\n",
    "    \"start\": 0,\n",
    "    \"step_1\": 1,\n",
    "    \"step_2\": 2,\n",
    "    \"step_3\": 3,\n",
    "    \"confirm\": 4\n",
    "}\n",
    "\n",
    "df[\"step_num\"] = df[\"process_step\"].map(step_order)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "fb749811-e700-4f24-a0f2-b26c7b348ed6",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Keep only After last 'start'\n",
    "last_start = (\n",
    "    df[df[\"process_step\"] == \"start\"]\n",
    "    .groupby(\"visit_id\")[\"date_time\"]\n",
    "    .max()\n",
    "    .reset_index()\n",
    "    .rename(columns={\"date_time\": \"last_start_time\"})\n",
    ")\n",
    "\n",
    "df = df.merge(last_start, on=\"visit_id\", how=\"left\")\n",
    "\n",
    "df = df[df[\"date_time\"] >= df[\"last_start_time\"]]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "0666c6d4-631e-4cf2-8892-646aadb5f85d",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Considering only last 'confirm'\n",
    "last_confirm = (\n",
    "    df[df[\"process_step\"] == \"confirm\"]\n",
    "    .groupby(\"visit_id\")[\"date_time\"]\n",
    "    .max()\n",
    "    .reset_index()\n",
    "    .rename(columns={\"date_time\": \"last_confirm_time\"})\n",
    ")\n",
    "\n",
    "df = df.merge(last_confirm, on=\"visit_id\", how=\"left\")"
   ]
  },
  {
